# ============================================================
# KIGO WEB APP — Variables de entorno
# ============================================================
# Copia este archivo como .env y reemplaza los valores mock
# con las credenciales reales cuando conectes los servicios.
#
# Para el prototipo, los valores aquí presentes permiten que
# la app funcione con datos simulados (mock mode).
# ============================================================

# --- Modo de ejecución ---
VITE_APP_ENV=development
# Opciones: development | staging | production

# --- API Backend (tu servicio propio) ---
VITE_API_BASE_URL=http://localhost:3001/api
# URL base del backend que provee datos de sesión, usuario y pagos.
# En producción será algo como: https://api.kigo.app/v1

VITE_API_TIMEOUT=10000
# Timeout en ms para llamadas al backend

# --- WhatsApp Bot / Sesión ---
VITE_SESSION_PARAM_KEY=session
# Nombre del query param que el bot envía en la URL.
# Ejemplo: https://pay.kigo.app?session=abc123

# --- Servicio de Pagos ---
VITE_PAYMENT_PROVIDER=stripe
# Proveedor de pagos. Opciones: stripe | mercadopago | conekta | paypal

VITE_STRIPE_PUBLISHABLE_KEY=pk_test_MOCK_1234567890abcdef
# Llave pública de Stripe (solo client-side, seguro exponerla)
# En producción: pk_live_...

VITE_MERCADOPAGO_PUBLIC_KEY=TEST-0000-0000-0000-000000000000
# Llave pública de MercadoPago (si se usa como proveedor)

VITE_PAYPAL_CLIENT_ID=sb-mock-client-id-1234567890
# Client ID de PayPal sandbox (si se usa como proveedor)

# --- Analytics (opcional) ---
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# Google Analytics 4 Measurement ID

VITE_SENTRY_DSN=https://mock@sentry.io/000000
# Sentry DSN para captura de errores en producción

# --- Feature Flags ---
VITE_ENABLE_MOCK_MODE=true
# true  = usa datos mock (prototipo)
# false = conecta a servicios reales

VITE_ENABLE_ANALYTICS=false
# true = activa analytics, false = desactivado

# ============================================================
# VARIABLES SOLO PARA BACKEND (NO exponer al cliente)
# Estas van en el servidor, no en Vite (sin prefijo VITE_)
# ============================================================

# STRIPE_SECRET_KEY=sk_test_MOCK_secretkey1234567890
# STRIPE_WEBHOOK_SECRET=whsec_MOCK_webhooksecret123
# MERCADOPAGO_ACCESS_TOKEN=TEST-0000000000000000-000000-00000000000000000000000000000000-000000000
# DATABASE_URL=postgresql://user:password@localhost:5432/kigo_db
# WHATSAPP_API_TOKEN=EAAxxxxxxx...
# WHATSAPP_PHONE_NUMBER_ID=000000000000000
# JWT_SECRET=super-secret-key-change-in-production
# SESSION_ENCRYPTION_KEY=32-byte-hex-key-here
